generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id            String    @id @default(uuid())
  shopDomain    String    @unique
  accessToken   String    // AES-256-GCM encrypted
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  webhooks       ShopifyWebhook[]
  syncEvents     ShopifySyncEvent[]
  orderPayments  ShopifyOrderPayment[]

  @@map("shops")
}

model ShopifyWebhook {
  id        String   @id @default(uuid())
  shopId    String
  topic     String
  endpoint  String
  shopifyId String?  // Shopify's numeric webhook ID
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, topic])
  @@map("shopify_webhooks")
}

// Financial-grade event journal. Every outbound event is persisted here
// before being sent to Orangepill. The unique constraint on
// (direction, eventType, idempotencyKey) is the ONLY thing that prevents
// double-billing — never remove it.
model ShopifySyncEvent {
  id             String   @id @default(uuid())
  shopId         String
  direction      String   // 'shopify_to_op'
  eventType      String   // 'order.finalized' | 'order.refunded'
  resourceId     String   // shopify order/refund id
  payloadJson    Json     // full payload stored for replay
  endpoint       String   // target URL (frozen at record time)
  idempotencyKey String
  status         String   @default("pending") // 'pending' | 'sent' | 'failed'
  attemptCount   Int      @default(0)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, direction, eventType, idempotencyKey])
  @@index([shopId, status])
  @@map("shopify_sync_events")
}

// Maps a Shopify order to its Orangepill checkout session.
// One active (pending) session per order at a time; failed/expired rows
// are left in place so new sessions can be created on retry.
model ShopifyOrderPayment {
  id                  String    @id @default(uuid())
  shopId              String
  shopifyOrderId      String
  orangepillSessionId String    @unique
  orangepillPaymentId String?
  checkoutUrl         String
  amount              String
  currency            String
  status              String    @default("pending") // 'pending' | 'paid' | 'failed' | 'expired'
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId, shopifyOrderId, status])
  @@map("shopify_order_payments")
}

// Inbound Orangepill webhook events. Keyed on X-Orangepill-Event-Id
// for at-most-once processing.
model OrangepillWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  deliveryId  String
  eventType   String
  sessionId   String
  payloadJson Json
  processedAt DateTime @default(now())

  @@map("orangepill_webhook_events")
}
