generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id            String    @id @default(uuid())
  shopDomain    String    @unique
  accessToken   String    // AES-256-GCM encrypted
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  webhooks      ShopifyWebhook[]
  syncEvents    ShopifySyncEvent[]
  orderPayments ShopifyOrderPayment[]
  attributions  ShopifyOrderAttribution[]
  settings      ShopSettings?

  @@map("shops")
}

// Per-shop conversational commerce settings.
model ShopSettings {
  id                  String   @id @default(uuid())
  shopId              String   @unique
  shop                Shop     @relation(fields: [shopId], references: [id])
  webchatEnabled      Boolean  @default(false)
  webchatEntrypointId String?
  webchatEmbedUrl     String?
  identitySecret      String?  // HMAC key for signing identity tokens; AES-256-GCM encrypted
  whatsappEnabled     Boolean  @default(false)
  whatsappNumber      String?
  whatsappFlowId      String?  // Orangepill flow entrypoint ID (alternative to phone number)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("shop_settings")
}

// Order-level conversation attribution. Written at checkout creation time and
// by future agent/WhatsApp order entry points. Looked up when orders/paid fires
// so conversationId + channelSessionId travel to Orangepill with the order event.
model ShopifyOrderAttribution {
  id               String   @id @default(uuid())
  shopId           String
  shopifyOrderId   String
  conversationId   String?
  channelSessionId String?
  source           String   // 'checkout_session' | 'agent' | 'manual'
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, shopifyOrderId])
  @@map("shopify_order_attributions")
}

model ShopifyWebhook {
  id        String   @id @default(uuid())
  shopId    String
  topic     String
  endpoint  String
  shopifyId String?
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, topic])
  @@map("shopify_webhooks")
}

// Financial-grade event journal. Every outbound event is persisted here
// before being sent to Orangepill. The unique constraint on
// (shopId, direction, eventType, idempotencyKey) is the ONLY thing that prevents
// double-billing — never remove it.
model ShopifySyncEvent {
  id             String    @id @default(uuid())
  shopId         String
  direction      String    // 'shopify_to_op'
  eventType      String    // 'order.finalized' | 'order.refunded'
  resourceId     String
  payloadJson    Json
  endpoint       String    // frozen at record time
  idempotencyKey String
  status         String    @default("pending") // 'pending' | 'sent' | 'failed' | 'retry_scheduled' | 'dead_letter'
  attemptCount   Int       @default(0)
  lastError      String?
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?
  deadLetteredAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, direction, eventType, idempotencyKey])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([shopId, status, nextRetryAt])
  @@index([status, nextRetryAt])
  @@map("shopify_sync_events")
}

// One row per (shopId, shopifyOrderId). On retry after failure/expiry the row
// is updated in-place with the new session details.
// status: 'pending' | 'processing' | 'paid' | 'failed' | 'expired'
//   processing = Shopify transaction call is in-flight; acts as distributed lock.
model ShopifyOrderPayment {
  id                   String    @id @default(uuid())
  shopId               String
  shopifyOrderId       String
  orangepillSessionId  String    @unique
  orangepillPaymentId  String?
  shopifyTransactionId String?   // set after successful Shopify transaction capture
  checkoutUrl          String
  amount               String
  currency             String
  orderAmount          String?   // original Shopify order amount (for multi-currency display)
  orderCurrency        String?   // original Shopify order currency
  conversationId       String?   // Orangepill conversation attribution
  channelSessionId     String?   // Orangepill channel session attribution
  status               String    @default("pending")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, shopifyOrderId])
  @@map("shopify_order_payments")
}

// Inbound Orangepill webhook events — keyed on X-Orangepill-Event-Id.
// payloadHash detects same eventId re-delivered with a different body (provider anomaly).
model OrangepillWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  deliveryId  String
  eventType   String
  sessionId   String
  payloadHash String   // sha256(rawBody) — stored for hash-mismatch anomaly detection
  payloadJson Json
  processedAt DateTime @default(now())

  @@map("orangepill_webhook_events")
}
