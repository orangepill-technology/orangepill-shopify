# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Shopify App Credentials
# Get from https://partners.shopify.com → Apps → Your App → API credentials
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_orders,read_customers
SHOPIFY_API_VERSION=2024-01

# Public URL of this app (must be HTTPS for Shopify webhooks)
# Use ngrok for local dev: ngrok http 3000
APP_URL=https://your-app.ngrok-free.dev

# Database
DATABASE_URL=postgresql://shopify:shopify123@localhost:5433/shopify_app

# Token encryption — must be at least 32 characters
ENCRYPTION_KEY=change-me-to-a-random-32-char-secret

# Orangepill API
ORANGEPILL_API_URL=https://console.orangepill.cloud
ORANGEPILL_API_KEY=your-orangepill-api-key
# UUID of the commerce.provider_integrations row for this Shopify channel
ORANGEPILL_INTEGRATION_ID=00000000-0000-0000-0000-000000000000
